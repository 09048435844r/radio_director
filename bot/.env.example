# Discord bot token (Discord Developer Portal で取得)
DISCORD_TOKEN=your-discord-bot-token-here

# /run /status を実行できる Discord ユーザー ID (整数)
# Discord 上で「ユーザーID をコピー」(開発者モード ON 必須) して貼り付け
ALLOWED_USER_ID=000000000000000000

# (任意) パイプラインのパス上書き。未指定なら ~/research_pipeline と ~/radio_director を使う
# RESEARCH_PIPELINE_DIR=/Users/tada/research_pipeline
# RADIO_DIRECTOR_DIR=/Users/tada/radio_director
